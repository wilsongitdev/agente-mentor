# ─────────────────────────────────────────────
#  CV Analyzer – environment variables template
#  Copy to .env and fill in your values
# ─────────────────────────────────────────────

# ── LLM Provider ──────────────────────────────
# Options: "openai" | "bedrock"
LLM_PROVIDER=bedrock

# OpenAI (used when LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# AWS Bedrock (usado cuando LLM_PROVIDER=bedrock)
AWS_ACCESS_KEY_ID=tu_aws_access_key
AWS_SECRET_ACCESS_KEY=tu_aws_secret_key
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-3-5-haiku-20241022-v2:0  # Haiku: Rápido y económico para el grafo

# ── Embeddings ────────────────────────────────
EMBEDDING_MODEL=text-embedding-3-small   # OpenAI embedding model
EMBEDDING_DIMENSION=1536

# ── Firebase ──────────────────────────────────
FIREBASE_CREDENTIALS_PATH=./config/firebase_credentials.json
FIREBASE_DATABASE_URL=https://<your-project>.firebaseio.com

# ── Vector Store ──────────────────────────────
# Options: "faiss" | "chroma"
VECTOR_STORE_TYPE=faiss
FAISS_INDEX_PATH=./db/faiss_index
CHROMA_PERSIST_DIR=./db/chroma

# ── API ───────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=true
SECRET_KEY=change-me-in-production

# ── File Upload ───────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# ── Logging ───────────────────────────────────
LOG_LEVEL=INFO

# ── LangSmith (Evaluación) ────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_PROJECT=agente-mentor
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# ── Modelos de Evaluación ─────────────────────
# El Juez suele usar un modelo más potente para auditar la calidad (ej: Sonnet o GPT-4o)
JUDGE_MODEL_ID=anthropic.claude-3-5-sonnet-20240620-v1:0

# ── E2B Sandbox (Seguridad) ───────────────────
# Obtén tu llave en https://e2b.dev
E2B_API_KEY=e2b_...
