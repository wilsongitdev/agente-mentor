# ─────────────────────────────────────────────
#  CV Analyzer – environment variables template
#  Copy to .env and fill in your values
# ─────────────────────────────────────────────

# ── LLM Provider ──────────────────────────────
# Options: "openai" | "bedrock"
LLM_PROVIDER=openai

# OpenAI (used when LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# AWS Bedrock (used when LLM_PROVIDER=bedrock)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0

# ── Embeddings ────────────────────────────────
EMBEDDING_MODEL=text-embedding-3-small   # OpenAI embedding model
EMBEDDING_DIMENSION=1536

# ── Firebase ──────────────────────────────────
FIREBASE_CREDENTIALS_PATH=./config/firebase_credentials.json
FIREBASE_DATABASE_URL=https://<your-project>.firebaseio.com

# ── Vector Store ──────────────────────────────
# Options: "faiss" | "chroma"
VECTOR_STORE_TYPE=faiss
FAISS_INDEX_PATH=./db/faiss_index
CHROMA_PERSIST_DIR=./db/chroma

# ── API ───────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=true
SECRET_KEY=change-me-in-production

# ── File Upload ───────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# ── Logging ───────────────────────────────────
LOG_LEVEL=INFO
